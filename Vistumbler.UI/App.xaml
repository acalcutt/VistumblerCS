<Application x:Class="Vistumbler.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:conv="clr-namespace:Vistumbler.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Add custom styles here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Theme brushes (updated at runtime by SettingsViewModel) ── -->
            <SolidColorBrush x:Key="PrimaryBrush"  Color="#99B4A1"/>  <!-- Window background    -->
            <SolidColorBrush x:Key="ControlBrush"  Color="#D7E4C2"/>  <!-- Control background   -->
            <SolidColorBrush x:Key="TextBrush"     Color="#000000"/>  <!-- Foreground / text     -->
            <SolidColorBrush x:Key="ActiveBrush"   Color="#E1F2D0"/>  <!-- Button active state   -->
            <SolidColorBrush x:Key="InactiveBrush" Color="#F2D0D0"/>  <!-- Button inactive state -->
            <!-- Font size (also updated at runtime) -->
            <sys:Double x:Key="GuiFontSize">11</sys:Double>

            <!-- Global Converters -->
            <conv:EnumToBooleanConverter x:Key="EnumBoolConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>
            <conv:SignalToColorConverter x:Key="SignalColorConverter"/>
            <conv:AuthToLockGlyphConverter x:Key="AuthLockConverter"/>

            <!-- ── Global implicit styles — apply theme to ALL windows ── -->
            <!-- Window: background colour -->
            <Style TargetType="Window">
                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="TextElement.FontSize"   Value="{DynamicResource GuiFontSize}"/>
            </Style>

            <!-- Named base styles — windows with local overrides use BasedOn="{StaticResource AppXxxStyle}" -->
            <Style x:Key="AppTextBlockStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize"   Value="{DynamicResource GuiFontSize}"/>
            </Style>
            <Style x:Key="AppTextBoxStyle" TargetType="TextBox">
                <Setter Property="Foreground"  Value="{DynamicResource TextBrush}"/>
                <Setter Property="Background"  Value="{DynamicResource ControlBrush}"/>
                <Setter Property="FontSize"    Value="{DynamicResource GuiFontSize}"/>
                <Setter Property="BorderBrush" Value="#888"/>
            </Style>
            <Style x:Key="AppLabelStyle" TargetType="Label">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize"   Value="{DynamicResource GuiFontSize}"/>
            </Style>
            <Style x:Key="AppCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize"   Value="{DynamicResource GuiFontSize}"/>
            </Style>
            <Style x:Key="AppRadioButtonStyle" TargetType="RadioButton">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize"   Value="{DynamicResource GuiFontSize}"/>
            </Style>
            <Style x:Key="AppButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize"   Value="{DynamicResource GuiFontSize}"/>
            </Style>
            <Style x:Key="AppComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize"   Value="{DynamicResource GuiFontSize}"/>
            </Style>
            <Style x:Key="AppGroupBoxStyle" TargetType="GroupBox">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize"   Value="{DynamicResource GuiFontSize}"/>
            </Style>
            <Style x:Key="AppTabItemStyle" TargetType="TabItem">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="FontSize"   Value="{DynamicResource GuiFontSize}"/>
            </Style>

            <!-- Implicit styles (apply to windows that don't override locally) -->
            <Style TargetType="TextBlock"   BasedOn="{StaticResource AppTextBlockStyle}"/>
            <Style TargetType="TextBox"     BasedOn="{StaticResource AppTextBoxStyle}"/>
            <Style TargetType="Label"       BasedOn="{StaticResource AppLabelStyle}"/>
            <Style TargetType="CheckBox"    BasedOn="{StaticResource AppCheckBoxStyle}"/>
            <Style TargetType="RadioButton" BasedOn="{StaticResource AppRadioButtonStyle}"/>
            <Style TargetType="Button"      BasedOn="{StaticResource AppButtonStyle}"/>
            <Style TargetType="ComboBox"    BasedOn="{StaticResource AppComboBoxStyle}"/>
            <Style TargetType="GroupBox"    BasedOn="{StaticResource AppGroupBoxStyle}"/>
            <Style TargetType="TabItem"     BasedOn="{StaticResource AppTabItemStyle}"/>
            <Style TargetType="MenuItem">
                <Setter Property="FontSize" Value="{DynamicResource GuiFontSize}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
