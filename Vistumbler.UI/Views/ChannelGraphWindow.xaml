<Window x:Class="Vistumbler.UI.Views.ChannelGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Vistumbler.UI.Controls"
        Title="Channel Graph"
        Width="860" Height="460"
        MinWidth="500" MinHeight="280"
        ResizeMode="CanResize">
    <DockPanel>
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <ToggleButton x:Name="UseRssiToggle"
                          Content="Use RSSI (dBm)"
                          Padding="6,2"
                          Checked="UseRssiToggle_Changed"
                          Unchecked="UseRssiToggle_Changed"
                          ToolTip="Toggle between signal % and RSSI dBm on the Y axis"/>
            <Separator/>
            <TextBlock x:Name="BandLabel" VerticalAlignment="Center" Margin="4,0"
                       FontWeight="SemiBold"/>
            <Separator/>
            <TextBlock Text="Channels 1/6/11 highlighted (2.4 GHz)" VerticalAlignment="Center"
                       Margin="4,0" Foreground="DimGray" FontStyle="Italic"
                       x:Name="HintLabel"/>
        </ToolBar>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="StatusText" Text="Waiting for scan data…"/>
        </StatusBar>

        <!-- Graph control -->
        <controls:ChannelGraphControl x:Name="GraphControl" Margin="4"/>
    </DockPanel>
</Window>
