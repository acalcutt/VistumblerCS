<Window x:Class="Vistumbler.UI.Views.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Vistumbler.UI.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Import Access Points" Height="300" Width="500" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ObjectDataProvider x:Key="ImportTypeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="viewmodels:ImportType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Import Settings" Grid.Row="0" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Import Type:" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <ComboBox Grid.Column="1" Margin="0,0,0,10" 
                          ItemsSource="{Binding Source={StaticResource ImportTypeEnum}}"
                          SelectedItem="{Binding SelectedImportType}"/>

                <TextBlock Grid.Row="1" Text="File:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Grid Grid.Row="1" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding FilePath}" IsReadOnly="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Button Content="Browse..." Grid.Column="1" Command="{Binding BrowseCommand}" Padding="10,2"/>
                </Grid>
            </Grid>
        </GroupBox>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,10" FontWeight="Bold"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Import" Command="{Binding ImportCommand}" Margin="0,0,10,0" Padding="20,5" IsDefault="True"/>
            <Button Content="Close" Command="{Binding CloseCommand}" Padding="20,5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
