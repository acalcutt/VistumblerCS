<Window x:Class="Vistumbler.UI.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vistumbler" SizeToContent="WidthAndHeight" MinWidth="340"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <TextBox   x:Name="InputBox"   Grid.Row="1" MinWidth="300" Padding="4,3"
                   KeyDown="InputBox_KeyDown"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK"     Width="80" IsDefault="True" Click="Ok_Click"     Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True"  Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
