<Window x:Class="Vistumbler.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Vistumbler.UI.ViewModels"
        xmlns:controls="clr-namespace:Vistumbler.UI.Controls"
        mc:Ignorable="d"
        Title="Vistumbler CS - WiFi Scanner" Height="800" Width="1400"
        Background="{StaticResource PrimaryBrush}">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="New Session"/>
                <MenuItem Header="Import">
                    <MenuItem Header="Import" Command="{Binding OpenImportWindowCommand}"/>
                    <MenuItem Header="Import Folder"/>
                </MenuItem>
                <MenuItem Header="Export">
                    <MenuItem Header="Export To VS1" Command="{Binding ExportVs1Command}"/>
                    <MenuItem Header="Export To VSZ" Command="{Binding ExportVszCommand}"/>
                    <MenuItem Header="Export To CSV" Command="{Binding ExportCsvCommand}"/>
                    <MenuItem Header="Export To KML" Command="{Binding ExportKmlCommand}"/>
                    <MenuItem Header="Export To GPX" Command="{Binding ExportGpxCommand}"/>
                    <MenuItem Header="Export To NS1" Command="{Binding ExportNs1Command}"/>
                    <MenuItem Header="Export To NetXML" Command="{Binding ExportNetXmlCommand}"/>
                    <MenuItem Header="Export To KismetDB" Command="{Binding ExportKismetDbCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Exit (Save DB)"/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Clear All" Command="{Binding ClearAllCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="GPS Details"/>
                <MenuItem Header="Graph">
                    <MenuItem Header="Line Graph (Graph1)" Command="{Binding ToggleGraph1Command}"
                              IsCheckable="True"
                              IsChecked="{Binding GraphMode,
                                Converter={StaticResource EnumBoolConverter},
                                ConverterParameter=Line, Mode=OneWay}"/>
                    <MenuItem Header="Bar Graph (Graph2)" Command="{Binding ToggleGraph2Command}"
                              IsCheckable="True"
                              IsChecked="{Binding GraphMode,
                                Converter={StaticResource EnumBoolConverter},
                                ConverterParameter=Bar, Mode=OneWay}"/>
                    <Separator/>
                    <MenuItem Header="Use RSSI in Graphs" Command="{Binding ToggleUseRssiCommand}"
                              IsCheckable="True"
                              IsChecked="{Binding UseRssiInGraphs, Mode=OneWay}"/>
                    <MenuItem Header="Graph Dead Time" Command="{Binding ToggleGraphDeadTimeCommand}"
                              IsCheckable="True"
                              IsChecked="{Binding GraphDeadTime, Mode=OneWay}"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}"/>
                <MenuItem Header="Auto Sort"/>
            </MenuItem>
            <MenuItem Header="_Extra">
                <MenuItem Header="Scan APs" Command="{Binding StartScanCommand}"/>
                <MenuItem Header="Stop Scan" Command="{Binding StopScanCommand}"/>
                <Separator/>
                <MenuItem Header="Use GPS" Command="{Binding StartGpsCommand}"/>
                <MenuItem Header="Stop GPS" Command="{Binding StopGpsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About"/>
            </MenuItem>
        </Menu>
        
        <!-- Toolbar -->
        <ToolBar Grid.Row="1" Background="{StaticResource AccentBrush}">
            <Button Content="Scan" Command="{Binding StartScanCommand}"
                    Background="{StaticResource ActiveBrush}"/>
            <Button Content="Stop" Command="{Binding StopScanCommand}"
                    Background="{StaticResource InactiveBrush}"/>
            <Separator/>
            <Button Content="GPS" Command="{Binding StartGpsCommand}"
                    Background="{StaticResource ActiveBrush}"/>
            <Button Content="Stop GPS" Command="{Binding StopGpsCommand}"
                    Background="{StaticResource InactiveBrush}"/>
            <Separator/>
            <TextBlock Text="Active APs:"/>
            <TextBlock Text="{Binding ActiveApCount}" FontWeight="Bold"/>
            <Separator/>
            <TextBlock Text="Latitude:"/>
            <TextBlock Text="{Binding CurrentLatitude}" FontWeight="Bold" MinWidth="100"/>
            <TextBlock Text="Longitude:"/>
            <TextBlock Text="{Binding CurrentLongitude}" FontWeight="Bold" MinWidth="100"/>
            <Separator/>
            <TextBlock Text="Loop Time:"/>
            <TextBlock Text="{Binding LoopTime, StringFormat={}{0:F0} ms}" FontWeight="Bold"/>
            <Separator/>
            <ToggleButton Content="Graph1" Padding="8,4"
                          IsChecked="{Binding GraphMode,
                            Converter={StaticResource EnumBoolConverter},
                            ConverterParameter=Line, Mode=TwoWay}"
                          Command="{Binding ToggleGraph1Command}" ToolTip="Line Graph"/>
            <ToggleButton Content="Graph2" Padding="8,4"
                          IsChecked="{Binding GraphMode,
                            Converter={StaticResource EnumBoolConverter},
                            ConverterParameter=Bar, Mode=TwoWay}"
                          Command="{Binding ToggleGraph2Command}" ToolTip="Bar Graph"/>
        </ToolBar>
        
        <!-- Signal Graph (visible only when Graph1/Graph2 active) -->
        <controls:SignalGraphControl
            Grid.Row="2"
            Height="100"
            Margin="10,10,10,0"
            Mode="{Binding GraphMode}"
            UseRssi="{Binding UseRssiInGraphs}"
            GraphDeadTime="{Binding GraphDeadTime}"
            SignalHistory="{Binding SelectedAccessPoint.SignalHistoryItems}"
            Visibility="{Binding IsGraphVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Main Content -->
        <Grid Grid.Row="3" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" MinWidth="100"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- NetStumbler-style Filter TreeView -->
            <Border Grid.Column="0" Background="White" BorderBrush="Gray" BorderThickness="1">
                <TreeView ItemsSource="{Binding TreeviewRoots}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          Background="White">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}"
                                                  ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" Padding="2,1"/>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>
            
            <!-- Access Points List -->
            <DataGrid Grid.Column="2"
                      ItemsSource="{Binding AccessPoints}"
                      SelectedItem="{Binding SelectedAccessPoint}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="All"
                      AlternatingRowBackground="LightGray"
                      Background="White">
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                              RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Copy" Command="{Binding CopyApInfoCommand}"/>
                        <Separator/>
                        <MenuItem Header="Add New Manufacturer" Command="{Binding AddManufacturerCommand}"/>
                        <MenuItem Header="Add New Label"        Command="{Binding AddLabelCommand}"/>
                        <Separator/>
                        <MenuItem Header="View Signal History"  Command="{Binding OpenSignalHistoryCommand}"/>
                        <Separator/>
                        <MenuItem Header="Geonames Info"        Command="{Binding OpenGeonamesCommand}"/>
                        <MenuItem Header="Find AP in WifiDB"    Command="{Binding FindApInWifiDbCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Active" Binding="{Binding ActiveDisplay}" Width="60"/>
                    <DataGridTextColumn Header="BSSID" Binding="{Binding Bssid}" Width="120"/>
                    <DataGridTextColumn Header="SSID" Binding="{Binding Ssid}" Width="150"/>
                    <DataGridTextColumn Header="Signal" Binding="{Binding DisplaySignal}" Width="70"/>
                    <DataGridTextColumn Header="High Signal" Binding="{Binding HighestSignal, StringFormat={}{0}%}" Width="90"/>
                    <DataGridTextColumn Header="RSSI" Binding="{Binding DisplayRssi}" Width="80"/>
                    <DataGridTextColumn Header="Channel" Binding="{Binding Channel}" Width="70"/>
                    <DataGridTextColumn Header="Radio Type" Binding="{Binding RadioType}" Width="90"/>
                    <DataGridTextColumn Header="Network Type" Binding="{Binding NetworkTypeDisplay}" Width="110"/>
                    <DataGridTextColumn Header="Auth" Binding="{Binding AuthenticationDisplay}" Width="100"/>
                    <DataGridTextColumn Header="Encryption" Binding="{Binding EncryptionDisplay}" Width="90"/>
                    <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="120"/>
                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="4" Background="{StaticResource AccentBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
