<Window x:Class="Vistumbler.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Vistumbler.UI.ViewModels"
        mc:Ignorable="d"
        Title="Vistumbler CS - WiFi Scanner" Height="800" Width="1400"
        Background="{StaticResource PrimaryBrush}">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="New Session"/>
                <MenuItem Header="Import">
                    <MenuItem Header="Import" Command="{Binding OpenImportWindowCommand}"/>
                    <MenuItem Header="Import Folder"/>
                </MenuItem>
                <MenuItem Header="Export">
                    <MenuItem Header="Export To VS1" Command="{Binding ExportVs1Command}"/>
                    <MenuItem Header="Export To VSZ" Command="{Binding ExportVszCommand}"/>
                    <MenuItem Header="Export To CSV" Command="{Binding ExportCsvCommand}"/>
                    <MenuItem Header="Export To KML" Command="{Binding ExportKmlCommand}"/>
                    <MenuItem Header="Export To GPX" Command="{Binding ExportGpxCommand}"/>
                    <MenuItem Header="Export To NS1" Command="{Binding ExportNs1Command}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Exit (Save DB)"/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Clear All" Command="{Binding ClearAllCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="GPS Details"/>
                <MenuItem Header="Signal Graph"/>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Settings"/>
                <MenuItem Header="Auto Sort"/>
            </MenuItem>
            <MenuItem Header="_Extra">
                <MenuItem Header="Scan APs" Command="{Binding StartScanCommand}"/>
                <MenuItem Header="Stop Scan" Command="{Binding StopScanCommand}"/>
                <Separator/>
                <MenuItem Header="Use GPS" Command="{Binding StartGpsCommand}"/>
                <MenuItem Header="Stop GPS" Command="{Binding StopGpsCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About"/>
            </MenuItem>
        </Menu>
        
        <!-- Toolbar -->
        <ToolBar Grid.Row="1" Background="{StaticResource AccentBrush}">
            <Button Content="Scan" Command="{Binding StartScanCommand}"
                    Background="{StaticResource ActiveBrush}"/>
            <Button Content="Stop" Command="{Binding StopScanCommand}"
                    Background="{StaticResource InactiveBrush}"/>
            <Separator/>
            <Button Content="GPS" Command="{Binding StartGpsCommand}"
                    Background="{StaticResource ActiveBrush}"/>
            <Button Content="Stop GPS" Command="{Binding StopGpsCommand}"
                    Background="{StaticResource InactiveBrush}"/>
            <Separator/>
            <TextBlock Text="Active APs:"/>
            <TextBlock Text="{Binding ActiveApCount}" FontWeight="Bold"/>
            <Separator/>
            <TextBlock Text="Latitude:"/>
            <TextBlock Text="{Binding CurrentLatitude}" FontWeight="Bold" MinWidth="100"/>
            <TextBlock Text="Longitude:"/>
            <TextBlock Text="{Binding CurrentLongitude}" FontWeight="Bold" MinWidth="100"/>
            <Separator/>
            <TextBlock Text="Loop Time:"/>
            <TextBlock Text="{Binding LoopTime, StringFormat={}{0:F0} ms}" FontWeight="Bold"/>
        </ToolBar>
        
        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Access Points List -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding AccessPoints}"
                      SelectedItem="{Binding SelectedAccessPoint}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="All"
                      AlternatingRowBackground="LightGray"
                      Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Active" Binding="{Binding ActiveDisplay}" Width="60"/>
                    <DataGridTextColumn Header="BSSID" Binding="{Binding Bssid}" Width="120"/>
                    <DataGridTextColumn Header="SSID" Binding="{Binding Ssid}" Width="150"/>
                    <DataGridTextColumn Header="Signal" Binding="{Binding DisplaySignal}" Width="70"/>
                    <DataGridTextColumn Header="High Signal" Binding="{Binding HighestSignal, StringFormat={}{0}%}" Width="90"/>
                    <DataGridTextColumn Header="RSSI" Binding="{Binding DisplayRssi}" Width="80"/>
                    <DataGridTextColumn Header="Channel" Binding="{Binding Channel}" Width="70"/>
                    <DataGridTextColumn Header="Radio Type" Binding="{Binding RadioType}" Width="90"/>
                    <DataGridTextColumn Header="Network Type" Binding="{Binding NetworkTypeDisplay}" Width="110"/>
                    <DataGridTextColumn Header="Auth" Binding="{Binding AuthenticationDisplay}" Width="100"/>
                    <DataGridTextColumn Header="Encryption" Binding="{Binding EncryptionDisplay}" Width="90"/>
                    <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="120"/>
                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
            
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>
            
            <!-- Details Panel -->
            <Border Grid.Column="2" Background="White" BorderBrush="Gray" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="Access Point Details" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="BSSID:"/>
                    <TextBlock Text="{Binding SelectedAccessPoint.Bssid}" FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <TextBlock Text="SSID:"/>
                    <TextBlock Text="{Binding SelectedAccessPoint.Ssid}" FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <TextBlock Text="Manufacturer:"/>
                    <TextBlock Text="{Binding SelectedAccessPoint.Manufacturer}" FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <TextBlock Text="Signal Strength:"/>
                    <TextBlock Text="{Binding SelectedAccessPoint.DisplaySignal}" FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <TextBlock Text="RSSI:"/>
                    <TextBlock Text="{Binding SelectedAccessPoint.DisplayRssi}" FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <TextBlock Text="Channel:"/>
                    <TextBlock Text="{Binding SelectedAccessPoint.Channel}" FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <TextBlock Text="First Seen:"/>
                    <TextBlock Text="{Binding SelectedAccessPoint.FirstSeen, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" 
                               FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <TextBlock Text="Last Seen:"/>
                    <TextBlock Text="{Binding SelectedAccessPoint.LastSeen, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" 
                               FontWeight="Bold" Margin="0,0,0,5"/>
                    
                    <Button Content="View Signal History" Margin="0,10,0,0"/>
                    <Button Content="Show on Map" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="{StaticResource AccentBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
