<Window x:Class="Vistumbler.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Vistumbler.UI.ViewModels"
        xmlns:controls="clr-namespace:Vistumbler.UI.Controls"
        xmlns:mlwpf="clr-namespace:MapLibreNative.Maui.WPF;assembly=MapLibreNative.Maui.WPF"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        MinHeight="500" MinWidth="800"
        Icon="pack://application:,,,/Assets/Vistumbler.ico"
        Background="{DynamicResource PrimaryBrush}">
    
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource AppButtonStyle}">
            <Setter Property="Margin"   Value="5"/>
            <Setter Property="Padding"  Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        
        <Style TargetType="TextBlock" BasedOn="{StaticResource AppTextBlockStyle}">
            <Setter Property="Margin"            Value="5,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="60"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="New Session" Command="{Binding NewSessionCommand}"/>
                <MenuItem Header="Import">
                    <MenuItem Header="Import" Command="{Binding OpenImportWindowCommand}"/>
                    <MenuItem Header="Import Folder" Command="{Binding OpenImportFolderCommand}"/>
                </MenuItem>
                <MenuItem Header="Export">
                    <MenuItem Header="Export To VS1" Command="{Binding ExportVs1Command}"/>
                    <MenuItem Header="Export To VSZ" Command="{Binding ExportVszCommand}"/>
                    <MenuItem Header="Export To CSV" Command="{Binding ExportCsvCommand}"/>
                    <MenuItem Header="Export To KML" Command="{Binding ExportKmlCommand}"/>
                    <MenuItem Header="Export To GPX" Command="{Binding ExportGpxCommand}"/>
                    <MenuItem Header="Export To NS1" Command="{Binding ExportNs1Command}"/>
                    <MenuItem Header="Export To NetXML" Command="{Binding ExportNetXmlCommand}"/>
                    <MenuItem Header="Export To KismetDB" Command="{Binding ExportKismetDbCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Exit (Save DB)" Command="{Binding ExitSaveDbCommand}"/>
                <MenuItem Header="Exit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Copy AP Info" Command="{Binding CopyApInfoCommand}"/>
                <MenuItem Header="Clear All" Command="{Binding ClearAllCommand}"/>
                <MenuItem Header="Sort Tree" Command="{Binding SortTreeCommand}"/>
                <MenuItem Header="Select Connected AP" Command="{Binding SelectConnectedApCommand}"/>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Scan APs" Command="{Binding ToggleScanCommand}"/>
                <Separator/>
                <MenuItem Header="Auto Refresh Networks" IsCheckable="True"
                          Command="{Binding ToggleAutoRefreshNetworksCommand}"
                          IsChecked="{Binding Settings.AutoRefreshNetworks, Mode=OneWay}"/>
                <MenuItem Header="Auto Recovery VS1" IsCheckable="True"
                          Command="{Binding ToggleAutoRecoveryCommand}"
                          IsChecked="{Binding Settings.AutoRecovery, Mode=OneWay}"/>
                <MenuItem Header="Auto Save And Clear" IsCheckable="True"
                          Command="{Binding ToggleAutoSaveAndClearCommand}"
                          IsChecked="{Binding Settings.AutoSaveAndClear, Mode=OneWay}"/>
                <MenuItem Header="Auto KML" IsCheckable="True"
                          Command="{Binding ToggleAutoKmlCommand}"
                          IsChecked="{Binding Settings.AutoKml, Mode=OneWay}"/>
                <MenuItem Header="Auto Scan APs on launch" IsCheckable="True"
                          Command="{Binding ToggleAutoScanOnLaunchCommand}"
                          IsChecked="{Binding Settings.AutoScanOnLaunch, Mode=OneWay}"/>
                <Separator/>
                <MenuItem Header="Play sound on new AP" IsCheckable="True"
                          Command="{Binding TogglePlaySoundCommand}"
                          IsChecked="{Binding Settings.PlaySound, Mode=OneWay}"/>
                <MenuItem Header="Play sound on new GPS" IsCheckable="True"
                          Command="{Binding TogglePlayGpsSoundCommand}"
                          IsChecked="{Binding Settings.PlayGpsSound, Mode=OneWay}"/>
                <MenuItem Header="Speak Signal" IsCheckable="True"
                          Command="{Binding ToggleSpeakSignalCommand}"
                          IsChecked="{Binding Settings.SpeakSignal, Mode=OneWay}"/>
                <MenuItem Header="Play MIDI sounds for all active APs" IsCheckable="True"
                          Command="{Binding TogglePlayMidiCommand}"
                          IsChecked="{Binding Settings.PlayMidiForActiveAps, Mode=OneWay}"/>
                <Separator/>
                <MenuItem Header="Save GPS data when no APs are active" IsCheckable="True"
                          Command="{Binding ToggleSaveGpsWhenNoApsCommand}"
                          IsChecked="{Binding Settings.SaveGpsWhenNoApsActive, Mode=OneWay}"/>
                <Separator/>
                <MenuItem Header="Download Images (Experimental)" IsCheckable="True"
                          Command="{Binding ToggleDownloadImagesCommand}"
                          IsChecked="{Binding Settings.DownloadImages, Mode=OneWay}"/>
                <MenuItem Header="Enable camera trigger script (Experimental)" IsCheckable="True"
                          Command="{Binding ToggleCameraTriggerCommand}"
                          IsChecked="{Binding Settings.EnableCameraTrigger, Mode=OneWay}"/>
                <MenuItem Header="Portable Mode (Experimental)" IsCheckable="True"
                          Command="{Binding TogglePortableModeCommand}"
                          IsChecked="{Binding Settings.PortableMode, Mode=OneWay}"/>
                <Separator/>
                <MenuItem Header="Debug">
                    <MenuItem Header="Display Debug" IsCheckable="True"
                              Command="{Binding ToggleDebugModeCommand}"
                              IsChecked="{Binding Settings.DebugMode, Mode=OneWay}"/>
                    <MenuItem Header="Display COM Errors" IsCheckable="True"
                              Command="{Binding ToggleDebugComCommand}"
                              IsChecked="{Binding Settings.DebugCom, Mode=OneWay}"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Filters" x:Name="FilterMenu">
                    <MenuItem Header="Add / Remove Filters..." Command="{Binding AddRemoveFiltersCommand}"/>
                    <MenuItem Header="Refresh Filters" Command="{Binding RefreshFiltersCommand}"/>
                    <Separator x:Name="FilterMenuSeparator"/>
                    <!-- Filter items are added dynamically in code-behind -->
                </MenuItem>
                <Separator/>
                <MenuItem Header="Graph" IsEnabled="{Binding IsGraphButtonsEnabled}">
                    <MenuItem Header="Line Graph (Graph1)" Command="{Binding ToggleGraph1Command}"
                              IsCheckable="True"
                              IsChecked="{Binding GraphMode,
                                Converter={StaticResource EnumBoolConverter},
                                ConverterParameter=Line, Mode=OneWay}"/>
                    <MenuItem Header="Bar Graph (Graph2)" Command="{Binding ToggleGraph2Command}"
                              IsCheckable="True"
                              IsChecked="{Binding GraphMode,
                                Converter={StaticResource EnumBoolConverter},
                                ConverterParameter=Bar, Mode=OneWay}"/>
                    <Separator/>
                    <MenuItem Header="Use RSSI in Graphs" Command="{Binding ToggleUseRssiCommand}"
                              IsCheckable="True"
                              IsChecked="{Binding UseRssiInGraphs, Mode=OneWay}"/>
                    <MenuItem Header="Graph Dead Time" Command="{Binding ToggleGraphDeadTimeCommand}"
                              IsCheckable="True"
                              IsChecked="{Binding GraphDeadTime, Mode=OneWay}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Auto Sort" IsCheckable="True"
                          Command="{Binding ToggleAutoSortCommand}"
                          IsChecked="{Binding Settings.AutoSort, Mode=OneWay}"/>
                <MenuItem Header="Auto Select Connected AP" IsCheckable="True"
                          Command="{Binding ToggleAutoSelectCommand}"
                          IsChecked="{Binding Settings.AutoSelectConnectedAp, Mode=OneWay}"/>
                <MenuItem Header="Auto Select High Signal" IsCheckable="True"
                          Command="{Binding ToggleAutoSelectHighSignalCommand}"
                          IsChecked="{Binding Settings.AutoSelectHighSignal, Mode=OneWay}"/>
                <MenuItem Header="Add New APs to Top" IsCheckable="True"
                          Command="{Binding ToggleAddNewApsToTopCommand}"
                          IsChecked="{Binding Settings.AddNewApsToTop, Mode=OneWay}"/>
                <MenuItem Header="Auto Scroll to Bottom" IsCheckable="True"
                          Command="{Binding ToggleAutoScrollToBottomCommand}"
                          IsChecked="{Binding Settings.AutoScrollToBottom, Mode=OneWay}"/>
                <MenuItem Header="Listview Batch Insert Mode (Experimental)" IsCheckable="True"
                          Command="{Binding ToggleBatchListviewInsertCommand}"
                          IsChecked="{Binding Settings.BatchListviewInsert, Mode=OneWay}"/>
                <Separator/>
                <MenuItem Header="Show Treeview" Command="{Binding ToggleTreeViewCommand}"
                          IsEnabled="{Binding IsTreeToggleEnabled}"
                          IsCheckable="True" IsChecked="{Binding ShowTreeView, Mode=OneWay}"/>
                <MenuItem Header="Minimal GUI (Experimental)" Command="{Binding ToggleListViewCommand}"
                          IsCheckable="True"
                          IsChecked="{Binding IsMinimalGuiMode, Mode=OneWay}"/>
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="Misc Settings"              Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="0"/>
                <MenuItem Header="Save Settings"              Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="1"/>
                <MenuItem Header="GPS Settings"               Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="2"/>
                <MenuItem Header="Set Language"               Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="3"/>
                <MenuItem Header="Set Manufactures by Mac"    Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="4"/>
                <MenuItem Header="Set Labels by Mac"          Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="5"/>
                <MenuItem Header="Set Column Widths"          Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="6"/>
                <MenuItem Header="Auto KML / AutoSort"        Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="7"/>
                <MenuItem Header="Sound"                      Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="8"/>
                <MenuItem Header="WifiDB"                     Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="9"/>
                <MenuItem Header="Set Cameras"                Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="10"/>
            </MenuItem>
            <MenuItem Header="_Interface" x:Name="InterfaceMenu">
                <MenuItem Header="Refresh Interfaces" Command="{Binding RefreshInterfacesCommand}"/>
                <Separator/>
                <!-- Adapter items are added dynamically in code-behind -->
            </MenuItem>
            <MenuItem Header="_Extra">
                <MenuItem Header="2.4 GHz Channel Graph (Experimental)" Command="{Binding Open24GHzGraphCommand}"/>
                <MenuItem Header="5 GHz Channel Graph (Experimental)"   Command="{Binding Open5GHzGraphCommand}"/>
                <MenuItem Header="6 GHz Channel Graph (Experimental)"   Command="{Binding Open6GHzGraphCommand}"/>
                <Separator/>
                <MenuItem Header="GPS Details" Command="{Binding OpenGpsDetailsCommand}"/>
                <MenuItem Header="GPS Compass" Command="{Binding OpenGpsCompassCommand}"/>
                <Separator/>
                <MenuItem Header="Upload APs to WifiDB" Command="{Binding UploadToWifiDbCommand}"/>
                <Separator/>
                <MenuItem Header="Open KML Network Link" Command="{Binding ToggleKmlNetworkLinkCommand}"
                          IsCheckable="True" IsChecked="{Binding IsKmlNetworkLinkActive, Mode=OneWay}"/>
                <MenuItem Header="Open Save Folder" Command="{Binding OpenSaveFolderCommand}"/>
                <Separator/>
                <MenuItem Header="Export Settings" Command="{Binding ExportSettingsCommand}"/>
                <MenuItem Header="Import Settings" Command="{Binding ImportSettingsCommand}"/>
                <Separator/>
                <MenuItem Header="Update Manufacturers" Command="{Binding UpdateManufacturersCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>
        
        <!-- Toolbar: two rows via ToolBarTray -->
        <ToolBarTray Grid.Row="1" Background="{DynamicResource ControlBrush}" IsLocked="True">

            <!-- Row 1: Scan / GPS / Save + status info -->
            <ToolBar Band="0" BandIndex="0" Background="{DynamicResource ControlBrush}">

                <!-- Scan toggle -->
                <Button Command="{Binding ToggleScanCommand}" Height="30" Padding="8,2">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource AppButtonStyle}">
                            <Setter Property="Content" Value="Scan APs"/>
                            <Setter Property="Background" Value="{DynamicResource InactiveBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                    <Setter Property="Content" Value="Stop Scan"/>
                                    <Setter Property="Background" Value="{DynamicResource ActiveBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- GPS toggle -->
                <Button Command="{Binding ToggleGpsCommand}" Height="30" Padding="8,2">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource AppButtonStyle}">
                            <Setter Property="Content" Value="Use GPS"/>
                            <Setter Property="Background" Value="{DynamicResource InactiveBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGpsActive}" Value="True">
                                    <Setter Property="Content" Value="Stop GPS"/>
                                    <Setter Property="Background" Value="{DynamicResource ActiveBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Save &amp; Clear" Command="{Binding SaveAndClearCommand}" Height="30" Padding="8,2"/>

                <Separator/>
                <TextBlock Text="Active APs:" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ActiveApCount}" FontWeight="Bold" Margin="2,0,6,0" VerticalAlignment="Center"/>
                <Separator/>
                <TextBlock Text="Lat:" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentLatitude}"  FontWeight="Bold" Margin="2,0,6,0" MinWidth="80" VerticalAlignment="Center"/>
                <TextBlock Text="Lon:" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentLongitude}" FontWeight="Bold" Margin="2,0,6,0" MinWidth="80" VerticalAlignment="Center"/>
                <Separator/>
                <TextBlock Text="Loop:" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding LoopTime, StringFormat={}{0:F0} ms}" FontWeight="Bold" Margin="2,0,6,0" VerticalAlignment="Center"/>
            </ToolBar>

            <!-- Row 2: Graph view toggles + show/hide panels -->
            <ToolBar Band="1" BandIndex="0" Background="{DynamicResource ControlBrush}">

                <!-- Graph toggles: Command-only (no conflicting TwoWay binding) -->
                <ToggleButton Command="{Binding ToggleGraphOffCommand}"
                              IsChecked="{Binding GraphMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Hidden, Mode=OneWay}"
                              IsEnabled="{Binding IsGraphButtonsEnabled}"
                              ToolTip="List only (hide graph and map)" Height="24" Padding="6,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4CB;" FontSize="9" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Text="List" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Command="{Binding ToggleGraph1Command}"
                              IsChecked="{Binding GraphMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Line, Mode=OneWay}"
                              IsEnabled="{Binding IsGraphButtonsEnabled}"
                              ToolTip="Line Graph" Height="24" Padding="6,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4C8;" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Line Graph" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Command="{Binding ToggleGraph2Command}"
                              IsChecked="{Binding GraphMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Bar, Mode=OneWay}"
                              IsEnabled="{Binding IsGraphButtonsEnabled}"
                              ToolTip="Bar Graph" Height="24" Padding="6,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F4CA;" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Bar Graph" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton Command="{Binding ToggleMapCommand}"
                              IsChecked="{Binding GraphMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Map, Mode=OneWay}"
                              IsEnabled="{Binding IsGraphButtonsEnabled}"
                              ToolTip="Map" Height="24" Padding="6,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F5FA;" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Map" VerticalAlignment="Center"/>
                    </StackPanel>
                </ToggleButton>
                <Separator/>

                <!-- Panel toggles -->
                <ToggleButton Content="Tree" Command="{Binding ToggleTreeViewCommand}"
                              IsChecked="{Binding ShowTreeView, Mode=OneWay}"
                              IsEnabled="{Binding IsTreeToggleEnabled}"
                              ToolTip="Show/Hide Treeview" Height="24" Padding="6,1"/>
                <ToggleButton Content="Mini" Command="{Binding ToggleListViewCommand}"
                              IsChecked="{Binding IsMinimalGuiMode, Mode=OneWay}"
                              ToolTip="Minimal GUI Mode (hides AP list, treeview and graph)" Height="24" Padding="6,1"/>
            </ToolBar>

        </ToolBarTray>
        
        <!-- Signal Graph (visible only when Graph1/Graph2 active) -->
        <controls:SignalGraphControl
            Grid.Row="2"
            Margin="10,10,10,0"
            Mode="{Binding GraphMode}"
            UseRssi="{Binding UseRssiInGraphs}"
            GraphDeadTime="{Binding GraphDeadTime}"
            DeadTimeSeconds="{Binding Settings.GraphGapThresholdSeconds}"
            SignalHistory="{Binding SelectedAccessPoint.SignalHistoryItems}"
            Visibility="{Binding IsGraphVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Map (visible only when Map mode active) -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsMapVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <mlwpf:MlnMapHost
                x:Name="MapHost"
                Grid.Row="0"
                Margin="10,10,10,0"
                StyleUrl="https://tiles.wifidb.net/styles/WDB_COLOR_RELIEF/style.json"/>

            <!-- AP info popup shown when a WifiDB map circle is clicked -->
            <Popup x:Name="ApInfoPopup"
                   PlacementTarget="{Binding ElementName=MapHost}"
                   Placement="RelativePoint"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="White" BorderBrush="#555" BorderThickness="1"
                        Padding="8,6" CornerRadius="4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.35" Direction="270"/>
                    </Border.Effect>
                    <TextBlock x:Name="ApInfoText" FontSize="11" MaxWidth="320" TextWrapping="Wrap"/>
                </Border>
            </Popup>

            <!-- WifiDB layer buttons: fetch and show GeoJSON from the WifiDB database -->
            <WrapPanel Grid.Row="1" Margin="10,4,10,4" Orientation="Horizontal">

                <Button Tag="WifiDB_daily"
                        ToolTip="Daily"
                        Content="Daily"
                        Click="WifiDbLayerButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"/>
                <Button Tag="WifiDB_weekly"
                        ToolTip="Weekly"
                        Content="Weekly"
                        Click="WifiDbLayerButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"/>
                <Button Tag="WifiDB_monthly"
                        ToolTip="Monthly"
                        Content="Monthly"
                        Click="WifiDbLayerButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"/>
                <Button Tag="WifiDB_0to1year"
                        ToolTip="0-1 Year"
                        Content="0-1 Year"
                        Click="WifiDbLayerButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"/>
                <Button Tag="WifiDB_1to2year"
                        ToolTip="1-2 Year"
                        Content="1-2 Year"
                        Click="WifiDbLayerButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"/>
                <Button Tag="WifiDB_2to3year"
                        ToolTip="2-3 Year"
                        Content="2-3 Year"
                        Click="WifiDbLayerButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"/>
                <Button Tag="WifiDB_3to5year"
                        ToolTip="3-5 Year"
                        Content="3-5 Year"
                        Click="WifiDbLayerButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"/>
                <Button Tag="WifiDB_5to10year"
                        ToolTip="5-10 Year"
                        Content="5-10 Year"
                        Click="WifiDbLayerButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"/>
                <Button Tag="WifiDB_10yrplus"
                        ToolTip="10+ Year"
                        Content="10+ Year"
                        Click="WifiDbLayerButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="4,0" VerticalAlignment="Stretch"/>

                <Button ToolTip="Cell Networks"
                        Content="Cell Networks"
                        Click="CellNetworksButton_Click"
                        Height="22" Padding="8,2" Margin="0,0,4,0"
                        FontSize="11"
                        Foreground="#885fcd"/>
            </WrapPanel>
        </Grid>

        <!-- Drag to resize between map/graph and the AP list below -->
        <GridSplitter Grid.Row="3"
                      Height="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Rows"
                      Background="{DynamicResource ControlBrush}"
                      Cursor="SizeNS"/>

        <!-- Main Content: hidden entirely in Minimal GUI mode -->
        <Grid Grid.Row="4" Margin="10"
              Visibility="{Binding IsContentVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="0"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- NetStumbler-style Filter TreeView -->
            <Border Grid.Column="0" Width="180" Background="White" BorderBrush="Gray" BorderThickness="1"
                    Visibility="{Binding IsTreeViewVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <TreeView ItemsSource="{Binding TreeviewRoots}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          Background="White">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}"
                                                  ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" Padding="2,1"/>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Visibility="{Binding IsTreeViewVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            
            <!-- Access Points List -->
            <ScrollViewer x:Name="ApListScroll"
                          Grid.Column="2"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <DataGrid HorizontalAlignment="Left"
                          MinWidth="{Binding ViewportWidth, ElementName=ApListScroll}"
                          ItemsSource="{Binding AccessPoints}"
                          SelectedItem="{Binding SelectedAccessPoint}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="All"
                          AlternatingRowBackground="LightGray"
                          Background="White"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          EnableColumnVirtualization="False"
                          EnableRowVirtualization="True">
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                              RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Copy" Command="{Binding CopyApInfoCommand}"/>
                        <Separator/>
                        <MenuItem Header="Add New Manufacturer" Command="{Binding AddManufacturerCommand}"/>
                        <MenuItem Header="Add New Label"        Command="{Binding AddLabelCommand}"/>
                        <Separator/>
                        <MenuItem Header="View Signal History"  Command="{Binding OpenSignalHistoryCommand}"/>
                        <Separator/>
                        <MenuItem Header="Geonames Info"        Command="{Binding OpenGeonamesCommand}"/>
                        <MenuItem Header="Find AP in WifiDB"    Command="{Binding FindApInWifiDbCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn x:Name="ColLineNumber" Header="#" Width="60" CanUserSort="True" SortMemberPath="LineNumber">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <Grid Width="18" Height="18">
                                        <Ellipse Fill="{Binding Signal, Converter={StaticResource SignalColorConverter}}"/>
                                        <TextBlock Text="{Binding Authentication, Converter={StaticResource AuthLockConverter}}"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White"/>
                                    </Grid>
                                    <TextBlock Text="{Binding LineNumber}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="ColActive"              Header="Active"               Binding="{Binding ActiveDisplay}"          Width="60"/>
                    <DataGridTextColumn x:Name="ColSsid"                Header="SSID"                 Binding="{Binding Ssid}"                   Width="150"/>
                    <DataGridTextColumn x:Name="ColMacAddress"          Header="Mac Address"          Binding="{Binding Bssid}"                  Width="110"/>
                    <DataGridTextColumn x:Name="ColSignal"              Header="Signal"               Binding="{Binding DisplaySignal}"          Width="75"/>
                    <DataGridTextColumn x:Name="ColHighSignal"          Header="High Signal"          Binding="{Binding HighestSignal, StringFormat={}{0}%}" Width="75"/>
                    <DataGridTextColumn x:Name="ColRssi"                Header="RSSI"                 Binding="{Binding DisplayRssi}"            Width="75"/>
                    <DataGridTextColumn x:Name="ColHighRssi"            Header="High RSSI"            Binding="{Binding HighRssiDisplay}"        Width="75"/>
                    <DataGridTextColumn x:Name="ColAuthentication"      Header="Authentication"       Binding="{Binding AuthenticationDisplay}"  Width="105"/>
                    <DataGridTextColumn x:Name="ColEncryption"          Header="Encryption"           Binding="{Binding EncryptionDisplay}"      Width="105"/>
                    <DataGridTextColumn x:Name="ColRadioType"           Header="Radio Type"           Binding="{Binding RadioType}"              Width="85"/>
                    <DataGridTextColumn x:Name="ColNetworkType"         Header="Network Type"         Binding="{Binding NetworkTypeDisplay}"     Width="100"/>
                    <DataGridTextColumn x:Name="ColChannel"             Header="Channel"              Binding="{Binding Channel}"                Width="70"/>
                    <DataGridTextColumn x:Name="ColFrequency"           Header="Frequency"            Binding="{Binding FrequencyDisplay}"       Width="80"  Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColManufacturer"        Header="Manufacturer"         Binding="{Binding Manufacturer}"           Width="110"/>
                    <DataGridTextColumn x:Name="ColLabel"               Header="Label"                Binding="{Binding Label}"                  Width="110"/>
                    <DataGridTextColumn x:Name="ColLatitude"            Header="Latitude"             Binding="{Binding LatitudeDisplay}"        Width="85"  Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLongitude"           Header="Longitude"            Binding="{Binding LongitudeDisplay}"       Width="85"  Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLatitudeDdmmss"      Header="Latitude (DDMMSS)"    Binding="{Binding LatitudeDdmmssDisplay}"  Width="115" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLongitudeDdmmss"     Header="Longitude (DDMMSS)"   Binding="{Binding LongitudeDdmmssDisplay}" Width="115" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLatitudeDdmmmm"      Header="Latitude (DDMMMM)"    Binding="{Binding LatitudeDdmmmmDisplay}"  Width="140" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLongitudeDdmmmm"     Header="Longitude (DDMMMM)"   Binding="{Binding LongitudeDdmmmmDisplay}" Width="140" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColBasicTransferRates"  Header="Basic Transfer Rates" Binding="{Binding BasicTransferRates}"     Width="130" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColOtherTransferRates"  Header="Other Transfer Rates" Binding="{Binding OtherTransferRates}"     Width="130" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColFirstActive"         Header="First Active"         Binding="{Binding FirstActiveDisplay}"     Width="130" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLastActive"          Header="Last Active"          Binding="{Binding LastActiveDisplay}"      Width="130" Visibility="Collapsed"/>
                </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Grid>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="5" Background="{DynamicResource ControlBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
