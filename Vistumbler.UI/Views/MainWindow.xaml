<Window x:Class="Vistumbler.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Vistumbler.UI.ViewModels"
        xmlns:controls="clr-namespace:Vistumbler.UI.Controls"
        mc:Ignorable="d"
        Title="Vistumbler CS - WiFi Scanner" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        MinHeight="500" MinWidth="800"
        Background="{StaticResource PrimaryBrush}">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="New Session"/>
                <MenuItem Header="Import">
                    <MenuItem Header="Import" Command="{Binding OpenImportWindowCommand}"/>
                    <MenuItem Header="Import Folder"/>
                </MenuItem>
                <MenuItem Header="Export">
                    <MenuItem Header="Export To VS1" Command="{Binding ExportVs1Command}"/>
                    <MenuItem Header="Export To VSZ" Command="{Binding ExportVszCommand}"/>
                    <MenuItem Header="Export To CSV" Command="{Binding ExportCsvCommand}"/>
                    <MenuItem Header="Export To KML" Command="{Binding ExportKmlCommand}"/>
                    <MenuItem Header="Export To GPX" Command="{Binding ExportGpxCommand}"/>
                    <MenuItem Header="Export To NS1" Command="{Binding ExportNs1Command}"/>
                    <MenuItem Header="Export To NetXML" Command="{Binding ExportNetXmlCommand}"/>
                    <MenuItem Header="Export To KismetDB" Command="{Binding ExportKismetDbCommand}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Exit (Save DB)"/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Clear All" Command="{Binding ClearAllCommand}"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="GPS Details"/>
                <MenuItem Header="Graph">
                    <MenuItem Header="Line Graph (Graph1)" Command="{Binding ToggleGraph1Command}"
                              IsCheckable="True"
                              IsChecked="{Binding GraphMode,
                                Converter={StaticResource EnumBoolConverter},
                                ConverterParameter=Line, Mode=OneWay}"/>
                    <MenuItem Header="Bar Graph (Graph2)" Command="{Binding ToggleGraph2Command}"
                              IsCheckable="True"
                              IsChecked="{Binding GraphMode,
                                Converter={StaticResource EnumBoolConverter},
                                ConverterParameter=Bar, Mode=OneWay}"/>
                    <Separator/>
                    <MenuItem Header="Use RSSI in Graphs" Command="{Binding ToggleUseRssiCommand}"
                              IsCheckable="True"
                              IsChecked="{Binding UseRssiInGraphs, Mode=OneWay}"/>
                    <MenuItem Header="Graph Dead Time" Command="{Binding ToggleGraphDeadTimeCommand}"
                              IsCheckable="True"
                              IsChecked="{Binding GraphDeadTime, Mode=OneWay}"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="Misc Settings"              Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="0"/>
                <MenuItem Header="Save Settings"              Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="1"/>
                <MenuItem Header="GPS Settings"               Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="2"/>
                <MenuItem Header="Set Language"               Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="3"/>
                <MenuItem Header="Set Manufactures by Mac"    Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="4"/>
                <MenuItem Header="Set Labels by Mac"          Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="5"/>
                <MenuItem Header="Set Column Widths"          Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="6"/>
                <MenuItem Header="Auto KML / AutoSort"        Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="7"/>
                <MenuItem Header="Sound"                      Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="8"/>
                <MenuItem Header="WifiDB"                     Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="9"/>
                <MenuItem Header="Set Cameras"                Command="{Binding OpenSettingsAtTabCommand}" CommandParameter="10"/>
                <MenuItem Header="Auto Sort"/>
            </MenuItem>
            <MenuItem Header="_Extra">
                <MenuItem Header="Scan APs" Command="{Binding StartScanCommand}"/>
                <MenuItem Header="Stop Scan" Command="{Binding StopScanCommand}"/>
                <Separator/>
                <MenuItem Header="Use GPS" Command="{Binding StartGpsCommand}"/>
                <MenuItem Header="Stop GPS" Command="{Binding StopGpsCommand}"/>
                <Separator/>
                <MenuItem Header="Update Manufacturers" Command="{Binding UpdateManufacturersCommand}"/>
                <Separator/>
                <MenuItem Header="2.4 GHz Channel Graph" Command="{Binding Open24GHzGraphCommand}"/>
                <MenuItem Header="5 GHz Channel Graph"   Command="{Binding Open5GHzGraphCommand}"/>
                <MenuItem Header="6 GHz Channel Graph"   Command="{Binding Open6GHzGraphCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About"/>
            </MenuItem>
        </Menu>
        
        <!-- Toolbar -->
        <ToolBar Grid.Row="1" Background="{StaticResource AccentBrush}">

            <!-- Scan toggle: red=inactive, green=active, text changes -->
            <Button Command="{Binding ToggleScanCommand}" Width="90" Height="45" Padding="4">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="Scan APs"/>
                        <Setter Property="Background" Value="{StaticResource InactiveBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                <Setter Property="Content" Value="Stop Scan"/>
                                <Setter Property="Background" Value="{StaticResource ActiveBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- GPS toggle: red=inactive, green=active, text changes -->
            <Button Command="{Binding ToggleGpsCommand}" Width="90" Height="45" Padding="4">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="Use GPS"/>
                        <Setter Property="Background" Value="{StaticResource InactiveBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsGpsActive}" Value="True">
                                <Setter Property="Content" Value="Stop GPS"/>
                                <Setter Property="Background" Value="{StaticResource ActiveBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="Save &amp; Clear" Command="{Binding SaveAndClearCommand}"
                    Width="90" Height="45" Padding="4"/>

            <Separator/>
            <TextBlock Text="Active APs:"/>
            <TextBlock Text="{Binding ActiveApCount}" FontWeight="Bold"/>
            <Separator/>
            <TextBlock Text="Latitude:"/>
            <TextBlock Text="{Binding CurrentLatitude}" FontWeight="Bold" MinWidth="100"/>
            <TextBlock Text="Longitude:"/>
            <TextBlock Text="{Binding CurrentLongitude}" FontWeight="Bold" MinWidth="100"/>
            <Separator/>
            <TextBlock Text="Loop Time:"/>
            <TextBlock Text="{Binding LoopTime, StringFormat={}{0:F0} ms}" FontWeight="Bold"/>
            <Separator/>
            <ToggleButton Content="Graph1" Padding="8,4"
                          IsChecked="{Binding GraphMode,
                            Converter={StaticResource EnumBoolConverter},
                            ConverterParameter=Line, Mode=TwoWay}"
                          Command="{Binding ToggleGraph1Command}" ToolTip="Line Graph"/>
            <ToggleButton Content="Graph2" Padding="8,4"
                          IsChecked="{Binding GraphMode,
                            Converter={StaticResource EnumBoolConverter},
                            ConverterParameter=Bar, Mode=TwoWay}"
                          Command="{Binding ToggleGraph2Command}" ToolTip="Bar Graph"/>
        </ToolBar>
        
        <!-- Signal Graph (visible only when Graph1/Graph2 active) -->
        <controls:SignalGraphControl
            Grid.Row="2"
            Height="300"
            Margin="10,10,10,0"
            Mode="{Binding GraphMode}"
            UseRssi="{Binding UseRssiInGraphs}"
            GraphDeadTime="{Binding GraphDeadTime}"
            SignalHistory="{Binding SelectedAccessPoint.SignalHistoryItems}"
            Visibility="{Binding IsGraphVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Main Content -->
        <Grid Grid.Row="3" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="0"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- NetStumbler-style Filter TreeView (hidden in graph mode) -->
            <Border Grid.Column="0" Width="180" Background="White" BorderBrush="Gray" BorderThickness="1"
                    Visibility="{Binding IsTreeViewVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <TreeView ItemsSource="{Binding TreeviewRoots}"
                          SelectedItemChanged="TreeView_SelectedItemChanged"
                          Background="White">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}"
                                                  ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" Padding="2,1"/>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Visibility="{Binding IsTreeViewVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            
            <!-- Access Points List -->
            <ScrollViewer x:Name="ApListScroll"
                          Grid.Column="2"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <DataGrid HorizontalAlignment="Left"
                          MinWidth="{Binding ViewportWidth, ElementName=ApListScroll}"
                          ItemsSource="{Binding AccessPoints}"
                          SelectedItem="{Binding SelectedAccessPoint}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="All"
                          AlternatingRowBackground="LightGray"
                          Background="White"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          EnableColumnVirtualization="False"
                          EnableRowVirtualization="True">
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                              RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Copy" Command="{Binding CopyApInfoCommand}"/>
                        <Separator/>
                        <MenuItem Header="Add New Manufacturer" Command="{Binding AddManufacturerCommand}"/>
                        <MenuItem Header="Add New Label"        Command="{Binding AddLabelCommand}"/>
                        <Separator/>
                        <MenuItem Header="View Signal History"  Command="{Binding OpenSignalHistoryCommand}"/>
                        <Separator/>
                        <MenuItem Header="Geonames Info"        Command="{Binding OpenGeonamesCommand}"/>
                        <MenuItem Header="Find AP in WifiDB"    Command="{Binding FindApInWifiDbCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ColLineNumber"          Header="#"                    Binding="{Binding LineNumber}"             Width="60"/>
                    <DataGridTextColumn x:Name="ColActive"              Header="Active"               Binding="{Binding ActiveDisplay}"          Width="60"/>
                    <DataGridTextColumn x:Name="ColSsid"                Header="SSID"                 Binding="{Binding Ssid}"                   Width="150"/>
                    <DataGridTextColumn x:Name="ColMacAddress"          Header="Mac Address"          Binding="{Binding Bssid}"                  Width="110"/>
                    <DataGridTextColumn x:Name="ColSignal"              Header="Signal"               Binding="{Binding DisplaySignal}"          Width="75"/>
                    <DataGridTextColumn x:Name="ColHighSignal"          Header="High Signal"          Binding="{Binding HighestSignal, StringFormat={}{0}%}" Width="75"/>
                    <DataGridTextColumn x:Name="ColRssi"                Header="RSSI"                 Binding="{Binding DisplayRssi}"            Width="75"/>
                    <DataGridTextColumn x:Name="ColHighRssi"            Header="High RSSI"            Binding="{Binding HighRssiDisplay}"        Width="75"/>
                    <DataGridTextColumn x:Name="ColAuthentication"      Header="Authentication"       Binding="{Binding AuthenticationDisplay}"  Width="105"/>
                    <DataGridTextColumn x:Name="ColEncryption"          Header="Encryption"           Binding="{Binding EncryptionDisplay}"      Width="105"/>
                    <DataGridTextColumn x:Name="ColRadioType"           Header="Radio Type"           Binding="{Binding RadioType}"              Width="85"/>
                    <DataGridTextColumn x:Name="ColNetworkType"         Header="Network Type"         Binding="{Binding NetworkTypeDisplay}"     Width="100"/>
                    <DataGridTextColumn x:Name="ColChannel"             Header="Channel"              Binding="{Binding Channel}"                Width="70"/>
                    <DataGridTextColumn x:Name="ColFrequency"           Header="Frequency"            Binding="{Binding FrequencyDisplay}"       Width="80"  Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColManufacturer"        Header="Manufacturer"         Binding="{Binding Manufacturer}"           Width="110"/>
                    <DataGridTextColumn x:Name="ColLabel"               Header="Label"                Binding="{Binding Label}"                  Width="110"/>
                    <DataGridTextColumn x:Name="ColLatitude"            Header="Latitude"             Binding="{Binding LatitudeDisplay}"        Width="85"  Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLongitude"           Header="Longitude"            Binding="{Binding LongitudeDisplay}"       Width="85"  Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLatitudeDdmmss"      Header="Latitude (DDMMSS)"    Binding="{Binding LatitudeDdmmssDisplay}"  Width="115" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLongitudeDdmmss"     Header="Longitude (DDMMSS)"   Binding="{Binding LongitudeDdmmssDisplay}" Width="115" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLatitudeDdmmmm"      Header="Latitude (DDMMMM)"    Binding="{Binding LatitudeDdmmmmDisplay}"  Width="140" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLongitudeDdmmmm"     Header="Longitude (DDMMMM)"   Binding="{Binding LongitudeDdmmmmDisplay}" Width="140" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColBasicTransferRates"  Header="Basic Transfer Rates" Binding="{Binding BasicTransferRates}"     Width="130" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColOtherTransferRates"  Header="Other Transfer Rates" Binding="{Binding OtherTransferRates}"     Width="130" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColFirstActive"         Header="First Active"         Binding="{Binding FirstActiveDisplay}"     Width="130" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="ColLastActive"          Header="Last Active"          Binding="{Binding LastActiveDisplay}"      Width="130" Visibility="Collapsed"/>
                </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Grid>
        
        <!-- Status Bar -->
        <StatusBar Grid.Row="4" Background="{StaticResource AccentBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
