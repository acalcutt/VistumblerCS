<Window x:Class="Vistumbler.UI.Views.SettingsWindow"        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"        xmlns:vm="clr-namespace:Vistumbler.UI.ViewModels"        xmlns:conv="clr-namespace:Vistumbler.UI.Converters"        mc:Ignorable="d"        Title="Vistumbler Settings" Height="680" Width="900"        ResizeMode="CanResize" WindowStartupLocation="CenterOwner"        Loaded="Window_Loaded">    <Window.Resources>        <conv:HexColorToBrushConverter x:Key="HexColorToBrush"/>        <BooleanToVisibilityConverter  x:Key="BoolVis"/>        <!-- Reuse global converters via App.xaml key -->        <Style x:Key="GroupLabel" TargetType="TextBlock">            <Setter Property="FontWeight" Value="SemiBold"/>            <Setter Property="Margin"     Value="0,0,0,2"/>        </Style>        <Style x:Key="FieldLabel" TargetType="TextBlock">            <Setter Property="VerticalAlignment" Value="Center"/>            <Setter Property="Margin"            Value="0,0,6,0"/>        </Style>        <Style TargetType="TextBox">            <Setter Property="Padding"       Value="4,2"/>            <Setter Property="VerticalContentAlignment" Value="Center"/>        </Style>        <Style TargetType="GroupBox">            <Setter Property="Margin" Value="0,0,0,8"/>            <Setter Property="Padding" Value="8,4,8,8"/>        </Style>    </Window.Resources>    <Grid Margin="8">        <Grid.RowDefinitions>            <RowDefinition Height="*"/>            <RowDefinition Height="Auto"/>        </Grid.RowDefinitions>        <TabControl Grid.Row="0"                    SelectedIndex="{Binding SelectedTabIndex}">            <!-- ══════════════ MISC ══════════════ -->            <TabItem Header="Misc">                <ScrollViewer VerticalScrollBarVisibility="Auto">                    <Grid Margin="8">                        <Grid.ColumnDefinitions>                            <ColumnDefinition Width="*"/>                            <ColumnDefinition Width="12"/>                            <ColumnDefinition Width="*"/>                        </Grid.ColumnDefinitions>                        <!-- LEFT column -->                        <StackPanel Grid.Column="0">                            <GroupBox Header="Update">                                <StackPanel>                                    <CheckBox Content="Automatically Check For Updates"                                              IsChecked="{Binding AutoCheckForUpdates}" Margin="0,4"/>                                    <CheckBox Content="Check For Beta Updates"                                              IsChecked="{Binding CheckForBetaUpdates}"/>                                </StackPanel>                            </GroupBox>                            <GroupBox Header="Misc">                                <Grid>                                    <Grid.ColumnDefinitions>                                        <ColumnDefinition Width="210"/>                                        <ColumnDefinition Width="*"/>                                    </Grid.ColumnDefinitions>                                    <Grid.RowDefinitions>                                        <RowDefinition Height="Auto"/>                                        <RowDefinition Height="Auto"/>                                        <RowDefinition Height="Auto"/>                                        <RowDefinition Height="Auto"/>                                    </Grid.RowDefinitions>                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Refresh loop time(ms):"/>                                    <TextBox Grid.Column="1" Text="{Binding RefreshLoopTimeMs}" Margin="0,3"/>                                    <TextBlock Grid.Row="1" Style="{StaticResource FieldLabel}" Text="Max Signal (dBm):"/>                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MaxSignalDbm}" Margin="0,3"/>                                    <TextBlock Grid.Row="2" Style="{StaticResource FieldLabel}" Text="Disassociation Signal (dBm):"/>                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DisassociationSignalDbm}" Margin="0,3"/>                                    <TextBlock Grid.Row="3" Style="{StaticResource FieldLabel}" Text="Time to wait before marking AP dead (s):"/>                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TimeBeforeMarkingDeadS}" Margin="0,3"/>                                </Grid>                            </GroupBox>                            <GroupBox Header="Auto Refresh Networks">                                <StackPanel>                                    <CheckBox Content="Auto Refresh Networks"                                              IsChecked="{Binding AutoRefreshNetworks}" Margin="0,4"/>                                    <Grid>                                        <Grid.ColumnDefinitions>                                            <ColumnDefinition Width="120"/>                                            <ColumnDefinition Width="*"/>                                        </Grid.ColumnDefinitions>                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Refresh time(s)"/>                                        <TextBox Grid.Column="1" Text="{Binding AutoRefreshNetworksTimeS}"/>                                    </Grid>                                </StackPanel>                            </GroupBox>                        </StackPanel>                        <!-- RIGHT column -->                        <StackPanel Grid.Column="2">                            <GroupBox Header="Color">                                <Grid>                                    <Grid.ColumnDefinitions>                                        <ColumnDefinition Width="160"/>                                        <ColumnDefinition Width="*"/>                                        <ColumnDefinition Width="14"/>                                        <ColumnDefinition Width="70"/>                                    </Grid.ColumnDefinitions>                                    <Grid.RowDefinitions>                                        <RowDefinition Height="Auto"/>                                        <RowDefinition Height="Auto"/>                                        <RowDefinition Height="Auto"/>                                        <RowDefinition Height="Auto"/>                                        <RowDefinition Height="Auto"/>                                    </Grid.RowDefinitions>                                    <!-- Background Color -->                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Background Color"/>                                    <TextBox Grid.Column="1" Text="{Binding BackgroundColorHex, UpdateSourceTrigger=PropertyChanged}" Margin="0,3"/>                                    <Rectangle Grid.Column="2" Width="12" Height="20" Margin="2,3,0,3"                                               Fill="{Binding BackgroundColorHex, Converter={StaticResource HexColorToBrush}}"/>                                    <Button Grid.Column="3" Content="Browse" Margin="4,3,0,3"                                            Tag="BackgroundColorHex" Click="ColorBrowse_Click"/>                                    <!-- Control Color -->                                    <TextBlock Grid.Row="1" Style="{StaticResource FieldLabel}" Text="Control Color"/>                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ControlColorHex, UpdateSourceTrigger=PropertyChanged}" Margin="0,3"/>                                    <Rectangle Grid.Row="1" Grid.Column="2" Width="12" Height="20" Margin="2,3,0,3"                                               Fill="{Binding ControlColorHex, Converter={StaticResource HexColorToBrush}}"/>                                    <Button Grid.Row="1" Grid.Column="3" Content="Browse" Margin="4,3,0,3"                                            Tag="ControlColorHex" Click="ColorBrowse_Click"/>                                    <!-- Font Color -->                                    <TextBlock Grid.Row="2" Style="{StaticResource FieldLabel}" Text="Font Color"/>                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding FontColorHex, UpdateSourceTrigger=PropertyChanged}" Margin="0,3"/>                                    <Rectangle Grid.Row="2" Grid.Column="2" Width="12" Height="20" Margin="2,3,0,3"                                               Fill="{Binding FontColorHex, Converter={StaticResource HexColorToBrush}}"/>                                    <Button Grid.Row="2" Grid.Column="3" Content="Browse" Margin="4,3,0,3"                                            Tag="FontColorHex" Click="ColorBrowse_Click"/>                                    <!-- Button Active Color -->                                    <TextBlock Grid.Row="3" Style="{StaticResource FieldLabel}" Text="Button Active Color"/>                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ButtonActiveColorHex, UpdateSourceTrigger=PropertyChanged}" Margin="0,3"/>                                    <Rectangle Grid.Row="3" Grid.Column="2" Width="12" Height="20" Margin="2,3,0,3"                                               Fill="{Binding ButtonActiveColorHex, Converter={StaticResource HexColorToBrush}}"/>                                    <Button Grid.Row="3" Grid.Column="3" Content="Browse" Margin="4,3,0,3"                                            Tag="ButtonActiveColorHex" Click="ColorBrowse_Click"/>                                    <!-- Button Inactive Color -->                                    <TextBlock Grid.Row="4" Style="{StaticResource FieldLabel}" Text="Button Inactive Color"/>                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding ButtonInactiveColorHex, UpdateSourceTrigger=PropertyChanged}" Margin="0,3"/>                                    <Rectangle Grid.Row="4" Grid.Column="2" Width="12" Height="20" Margin="2,3,0,3"                                               Fill="{Binding ButtonInactiveColorHex, Converter={StaticResource HexColorToBrush}}"/>                                    <Button Grid.Row="4" Grid.Column="3" Content="Browse" Margin="4,3,0,3"                                            Tag="ButtonInactiveColorHex" Click="ColorBrowse_Click"/>                                </Grid>                            </GroupBox>                            <GroupBox Header="Text">                                <Grid>                                    <Grid.ColumnDefinitions>                                        <ColumnDefinition Width="100"/>                                        <ColumnDefinition Width="*"/>                                    </Grid.ColumnDefinitions>                                    <TextBlock Style="{StaticResource FieldLabel}" Text="GUI Text Size"/>                                    <TextBox Grid.Column="1" Text="{Binding GuiTextSize}"/>                                </Grid>                            </GroupBox>                        </StackPanel>                    </Grid>                </ScrollViewer>            </TabItem>            <!-- ══════════════ SAVE ══════════════ -->            <TabItem Header="Save">                <ScrollViewer VerticalScrollBarVisibility="Auto">                    <Grid Margin="8">                        <Grid.ColumnDefinitions>                            <ColumnDefinition Width="*"/>                            <ColumnDefinition Width="12"/>                            <ColumnDefinition Width="*"/>                        </Grid.ColumnDefinitions>                        <Grid.RowDefinitions>                            <RowDefinition Height="Auto"/>                            <RowDefinition Height="*"/>                        </Grid.RowDefinitions>                        <!-- Save Directories (spans both columns) -->                        <GroupBox Grid.ColumnSpan="3" Header="Save Directories">                            <Grid>                                <Grid.RowDefinitions>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                </Grid.RowDefinitions>                                <!-- Row 0 -->                                <TextBlock Text="Vistumbler Save Directory" Margin="0,4,0,2"/>                                <!-- Row 1 -->                                <Grid Grid.Row="1" Margin="0,0,0,6">                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>                                    <TextBox Text="{Binding SaveDir}" IsReadOnly="True"/>                                    <Button Grid.Column="1" Content="Browse" Margin="4,0,0,0" Tag="SaveDir" Click="DirBrowse_Click"/>                                </Grid>                                <TextBlock Grid.Row="2" Text="Vistumbler Auto Save Directory" Margin="0,4,0,2"/>                                <Grid Grid.Row="3" Margin="0,0,0,6">                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>                                    <TextBox Text="{Binding SaveDirAuto}" IsReadOnly="True"/>                                    <Button Grid.Column="1" Content="Browse" Margin="4,0,0,0" Tag="SaveDirAuto" Click="DirBrowse_Click"/>                                </Grid>                            </Grid>                        </GroupBox>                        <!-- Additional dirs - below first group -->                        <GroupBox Grid.Row="1" Grid.ColumnSpan="3" Header="Additional Save Directories">                            <Grid>                                <Grid.RowDefinitions>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                </Grid.RowDefinitions>                                <TextBlock Text="Vistumbler Auto Recovery Save Directory" Margin="0,4,0,2"/>                                <Grid Grid.Row="1" Margin="0,0,0,6">                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>                                    <TextBox Text="{Binding SaveDirAutoRecovery}" IsReadOnly="True"/>                                    <Button Grid.Column="1" Content="Browse" Margin="4,0,0,0" Tag="SaveDirAutoRecovery" Click="DirBrowse_Click"/>                                </Grid>                                <TextBlock Grid.Row="2" Text="Vistumbler KML Save Directory" Margin="0,4,0,2"/>                                <Grid Grid.Row="3" Margin="0,0,0,6">                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>                                    <TextBox Text="{Binding SaveDirKml}" IsReadOnly="True"/>                                    <Button Grid.Column="1" Content="Browse" Margin="4,0,0,0" Tag="SaveDirKml" Click="DirBrowse_Click"/>                                </Grid>                            </Grid>                        </GroupBox>                    </Grid>                </ScrollViewer>            </TabItem>            <!-- ══════════════ GPS ══════════════ -->            <TabItem Header="GPS">                <ScrollViewer VerticalScrollBarVisibility="Auto">                    <StackPanel Margin="8">                        <GroupBox Header="Com Interface">                            <StackPanel>                                <RadioButton Content="Kemel32" IsChecked="{Binding GpsTypeKernel32}" Margin="0,3"/>                                <RadioButton Content="Netcomm OCX (Needs http://www.hardandsoftware.net/NETCommOCX.htm)"                                             IsChecked="{Binding GpsTypeNetcomm}" Margin="0,2"/>                                <RadioButton Content="CommMG (included, but will crash if gps is disconnected improperly)"                                             IsChecked="{Binding GpsTypeCommMg}" Margin="0,2"/>                            </StackPanel>                        </GroupBox>                        <GroupBox Header="Com Settings">                            <Grid>                                <Grid.ColumnDefinitions>                                    <ColumnDefinition Width="80"/>                                    <ColumnDefinition Width="120"/>                                    <ColumnDefinition Width="20"/>                                    <ColumnDefinition Width="80"/>                                    <ColumnDefinition Width="*"/>                                </Grid.ColumnDefinitions>                                <Grid.RowDefinitions>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                </Grid.RowDefinitions>                                <TextBlock Style="{StaticResource FieldLabel}" Text="Com"/>                                <ComboBox Grid.Column="1"                                          ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.ComPortOptions}}"                                          SelectedItem="{Binding ComPortNumber}" Margin="0,3"/>                                <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="Parity"/>                                <ComboBox Grid.Column="4"                                          ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.ParityOptions}}"                                          SelectedItem="{Binding Parity}" Margin="0,3"/>                                <TextBlock Grid.Row="1" Style="{StaticResource FieldLabel}" Text="Baud"/>                                <ComboBox Grid.Row="1" Grid.Column="1"                                          ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.BaudRateOptions}}"                                          SelectedItem="{Binding BaudRate}" Margin="0,3"/>                                <TextBlock Grid.Row="1" Grid.Column="3" Style="{StaticResource FieldLabel}" Text="Data Bit"/>                                <ComboBox Grid.Row="1" Grid.Column="4"                                          ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.DataBitOptions}}"                                          SelectedItem="{Binding DataBit}" Margin="0,3"/>                                <TextBlock Grid.Row="2" Style="{StaticResource FieldLabel}" Text="Stop Bit"/>                                <ComboBox Grid.Row="2" Grid.Column="1"                                          ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.StopBitOptions}}"                                          SelectedItem="{Binding StopBit}" Margin="0,3"/>                            </Grid>                        </GroupBox>                        <GroupBox Header="GPS Logging">                            <Grid>                                <Grid.ColumnDefinitions>                                    <ColumnDefinition Width="*"/>                                    <ColumnDefinition Width="80"/>                                </Grid.ColumnDefinitions>                                <Grid.RowDefinitions>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                </Grid.RowDefinitions>                                <CheckBox Grid.ColumnSpan="2" Content="Save NMEA Data to log file"                                          IsChecked="{Binding GpsLogEnabled}" Margin="0,3"/>                                <CheckBox Grid.Row="1" Grid.ColumnSpan="2" Content="Delete NMEA Data log file on exit"                                          IsChecked="{Binding GpsLogDeleteOnExit}" Margin="0,3"/>                                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,3">                                    <TextBlock Text="Log file location" VerticalAlignment="Center" Margin="0,0,6,0"/>                                    <TextBox Text="{Binding GpsLogLocation}" Width="300" IsReadOnly="True"/>                                    <Button Content="Browse" Margin="4,0,0,0" Click="GpsLogBrowse_Click"/>                                </StackPanel>                            </Grid>                        </GroupBox>                        <GroupBox Header="GPS Settings">                            <StackPanel>                                <StackPanel Orientation="Horizontal" Margin="0,3">                                    <TextBlock Text="GPS Format" VerticalAlignment="Center" Margin="0,0,8,0"/>                                    <ComboBox ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.GpsFormatOptions}}"                                              SelectedItem="{Binding GpsFormat}" Width="180"/>                                </StackPanel>                                <CheckBox Content="Disconnect GPS when no data is received in over 10 seconds"                                          IsChecked="{Binding GpsDisconnectOnTimeout}" Margin="0,3"/>                                <CheckBox Content="Reset GPS position when no GPGGA data is received in over 30 seconds"                                          IsChecked="{Binding GpsResetOnNoData}" Margin="0,3"/>                            </StackPanel>                        </GroupBox>                    </StackPanel>                </ScrollViewer>            </TabItem>            <!-- ══════════════ LANGUAGE ══════════════ -->            <TabItem Header="Language">                <StackPanel Margin="8">                    <GroupBox Header="Set Language">                        <StackPanel>                            <ComboBox ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.LanguageOptions}}"                                      SelectedItem="{Binding Language}" Margin="0,4"/>                            <Grid Margin="0,4">                                <Grid.ColumnDefinitions>                                    <ColumnDefinition Width="*"/>                                    <ColumnDefinition Width="16"/>                                    <ColumnDefinition Width="*"/>                                </Grid.ColumnDefinitions>                                <Grid.RowDefinitions>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="Auto"/>                                    <RowDefinition Height="100"/>                                </Grid.RowDefinitions>                                <GroupBox Header="Language Author">                                    <TextBlock Text="{Binding LanguageAuthor}" Padding="4,2"/>                                </GroupBox>                                <GroupBox Grid.Column="2" Header="Language Date">                                    <TextBlock Text="{Binding LanguageDate}" Padding="4,2"/>                                </GroupBox>                                <!-- language code spans -->                                <GroupBox Grid.Row="1" Header="Language Date">                                    <TextBlock Text="{Binding LanguageDate}" Padding="4,2"/>                                </GroupBox>                                <GroupBox Grid.Row="1" Grid.Column="2" Header="Language Code">                                    <TextBlock Text="{Binding LanguageCode}" Padding="4,2"/>                                </GroupBox>                                <GroupBox Grid.Row="2" Grid.ColumnSpan="3" Header="Language Description">                                    <TextBlock Text="{Binding LanguageDescription}" TextWrapping="Wrap" Padding="4,2"/>                                </GroupBox>                            </Grid>                        </StackPanel>                    </GroupBox>                    <GroupBox Header="Import Language File">                        <StackPanel>                            <Grid Margin="0,4">                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>                                <TextBox Text="{Binding LanguageImportPath}" IsReadOnly="True"/>                                <Button Grid.Column="1" Content="Browse" Margin="4,0,0,0" Click="LangBrowse_Click"/>                            </Grid>                            <Button Content="Import Language File" HorizontalAlignment="Center" Padding="16,4" Margin="0,4"/>                        </StackPanel>                    </GroupBox>                </StackPanel>            </TabItem>            <!-- ══════════════ MANUFACTURERS ══════════════ -->            <TabItem Header="Manufacturers">                <Grid Margin="8">                    <Grid.RowDefinitions>                        <RowDefinition Height="Auto"/>                        <RowDefinition Height="Auto"/>                        <RowDefinition Height="*"/>                    </Grid.RowDefinitions>                    <Grid Margin="0,0,0,6">                        <Grid.ColumnDefinitions>                            <ColumnDefinition Width="Auto"/>                            <ColumnDefinition Width="*"/>                            <ColumnDefinition Width="20"/>                            <ColumnDefinition Width="Auto"/>                            <ColumnDefinition Width="*"/>                        </Grid.ColumnDefinitions>                        <TextBlock Style="{StaticResource FieldLabel}" Text="New Mac Address:"/>                        <TextBox Grid.Column="1" Text="{Binding NewMacAddress, UpdateSourceTrigger=PropertyChanged}"/>                        <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="New Manufacturer:"/>                        <TextBox Grid.Column="4" Text="{Binding NewManufacturer, UpdateSourceTrigger=PropertyChanged}"/>                    </Grid>                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">                        <Button Content="Add New Manufacturer" Padding="16,4" Margin="0,0,8,0"                                Command="{Binding AddNewManufacturerCommand}"/>                        <Button Content="Remove Selected Manufacturer" Padding="16,4" Margin="0,0,8,0"                                Command="{Binding RemoveManufacturerCommand}"/>                        <Button Content="Edit Selected Manufacturer" Padding="16,4"                                Command="{Binding EditManufacturerCommand}"/>                    </StackPanel>                    <DataGrid Grid.Row="2"                              ItemsSource="{Binding Manufacturers}"                              SelectedItem="{Binding SelectedManufacturer}"                              AutoGenerateColumns="False" CanUserAddRows="False"                              IsReadOnly="True" SelectionMode="Single"                              AlternatingRowBackground="#F0F5F0">                        <DataGrid.Columns>                            <DataGridTextColumn Header="Mac Address"   Binding="{Binding MacPrefix}"    Width="180"/>                            <DataGridTextColumn Header="Manufacturer"  Binding="{Binding Manufacturer}" Width="*"/>                        </DataGrid.Columns>                    </DataGrid>                </Grid>            </TabItem>            <!-- ══════════════ LABELS ══════════════ -->            <TabItem Header="Labels">                <Grid Margin="8">                    <Grid.RowDefinitions>                        <RowDefinition Height="Auto"/>                        <RowDefinition Height="Auto"/>                        <RowDefinition Height="*"/>                    </Grid.RowDefinitions>                    <Grid Margin="0,0,0,6">                        <Grid.ColumnDefinitions>                            <ColumnDefinition Width="Auto"/>                            <ColumnDefinition Width="*"/>                            <ColumnDefinition Width="20"/>                            <ColumnDefinition Width="Auto"/>                            <ColumnDefinition Width="*"/>                        </Grid.ColumnDefinitions>                        <TextBlock Style="{StaticResource FieldLabel}" Text="New Mac Address:"/>                        <TextBox Grid.Column="1" Text="{Binding NewLabelMacAddress, UpdateSourceTrigger=PropertyChanged}"/>                        <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="New Label:"/>                        <TextBox Grid.Column="4" Text="{Binding NewLabel, UpdateSourceTrigger=PropertyChanged}"/>                    </Grid>                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">                        <Button Content="Add New Label" Padding="16,4" Margin="0,0,8,0"                                Command="{Binding AddNewLabelCommand}"/>                        <Button Content="Remove Selected Label" Padding="16,4" Margin="0,0,8,0"                                Command="{Binding RemoveLabelCommand}"/>                        <Button Content="Edit Selected Label" Padding="16,4"                                Command="{Binding EditLabelCommand}"/>                    </StackPanel>                    <DataGrid Grid.Row="2"                              ItemsSource="{Binding Labels}"                              SelectedItem="{Binding SelectedLabel}"                              AutoGenerateColumns="False" CanUserAddRows="False"                              IsReadOnly="True" SelectionMode="Single"                              AlternatingRowBackground="#F0F5F0">                        <DataGrid.Columns>                            <DataGridTextColumn Header="Mac Address" Binding="{Binding Bssid}" Width="220"/>                            <DataGridTextColumn Header="Label"       Binding="{Binding Label}" Width="*"/>                        </DataGrid.Columns>                    </DataGrid>                </Grid>            </TabItem>            <!-- ══════════════ COLUMNS ══════════════ -->            <TabItem Header="Columns">                <ScrollViewer VerticalScrollBarVisibility="Auto">                    <Grid Margin="8">                        <Grid.ColumnDefinitions>                            <ColumnDefinition Width="*"/>                            <ColumnDefinition Width="16"/>                            <ColumnDefinition Width="*"/>                        </Grid.ColumnDefinitions>                        <StackPanel Grid.Column="0">                            <TextBlock Text="Enable / Disable" FontWeight="Bold" Margin="0,0,0,4"/>                            <!-- Column row helper: CheckBox | label | width TextBox -->                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowLineNumber}"/>                                <TextBlock Grid.Column="1" Text="#" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding LineNumberWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowActive}"/>                                <TextBlock Grid.Column="1" Text="Active" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding ActiveWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowSsid}"/>                                <TextBlock Grid.Column="1" Text="SSID" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding SsidWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowMacAddress}"/>                                <TextBlock Grid.Column="1" Text="Mac Address" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding MacAddressWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowSignal}"/>                                <TextBlock Grid.Column="1" Text="Signal" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding SignalWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowHighSignal}"/>                                <TextBlock Grid.Column="1" Text="High Signal" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding HighSignalWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowRssi}"/>                                <TextBlock Grid.Column="1" Text="RSSI" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding RssiWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowHighRssi}"/>                                <TextBlock Grid.Column="1" Text="High RSSI" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding HighRssiWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowAuthentication}"/>                                <TextBlock Grid.Column="1" Text="Authentication" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding AuthenticationWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowEncryption}"/>                                <TextBlock Grid.Column="1" Text="Encryption" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding EncryptionWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowRadioType}"/>                                <TextBlock Grid.Column="1" Text="Radio Type" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding RadioTypeWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowNetworkType}"/>                                <TextBlock Grid.Column="1" Text="Network Type" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding NetworkTypeWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowChannel}"/>                                <TextBlock Grid.Column="1" Text="Channel" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding ChannelWidth}"/>                            </Grid>                        </StackPanel>                        <StackPanel Grid.Column="2">                            <TextBlock Text="Enable / Disable" FontWeight="Bold" Margin="0,0,0,4"/>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowManufacturer}"/>                                <TextBlock Grid.Column="1" Text="Manufacturer" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding ManufacturerWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowLabel}"/>                                <TextBlock Grid.Column="1" Text="Label" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding LabelWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowLatitude}"/>                                <TextBlock Grid.Column="1" Text="Latitude" VerticalAlignment="Center"/>                                <TextBox Grid.Column="2" Text="{Binding LatitudeWidth}"/>                            </Grid>                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="60"/></Grid.ColumnDefinitions>                                <CheckBox IsChecked="{Binding ShowLongitude}"/>                                <TextBlock Gri