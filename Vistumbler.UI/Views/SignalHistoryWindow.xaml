<Window x:Class="Vistumbler.UI.Views.SignalHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Signal History" Height="450" Width="620"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0"
                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding SignalHistoryItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"
                                    Binding="{Binding Timestamp, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}"
                                    Width="160"/>
                <DataGridTextColumn Header="Signal %" Binding="{Binding Signal}" Width="80"/>
                <DataGridTextColumn Header="RSSI (dBm)" Binding="{Binding Rssi}" Width="90"/>
                <DataGridTextColumn Header="Latitude"
                                    Binding="{Binding GpsData.Latitude, StringFormat=\{0:F6\}}"
                                    Width="*"/>
                <DataGridTextColumn Header="Longitude"
                                    Binding="{Binding GpsData.Longitude, StringFormat=\{0:F6\}}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
